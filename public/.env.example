# 环境变量示例文件（可选）
# 复制此文件为 .env 并修改相应配置
# 注意：这些配置会被后台管理界面的配置覆盖

# 用户ID（可选，有会员填写）
MIGU_USER_ID=

# 用户Token（可选，有会员填写）
MIGU_TOKEN=

# 运行端口（仅用于提示）
MIGU_PORT=8080

# 公网访问地址
MIGU_HOST=

# 画质：2标清 3高清 4蓝光
MIGU_RATE_TYPE=3

# 访问密码（可选）
MIGU_PASS=

# 开启HDR（true/false）
MIGU_ENABLE_HDR=true

# 开启H265（true/false）
MIGU_ENABLE_H265=true

# 数据更新间隔（小时）
MIGU_UPDATE_INTERVAL=6

# 忽略分类（逗号分隔）
MIGU_IGNORE_CATEGORY=

# 合并TV分类（true/false）
MIGU_MERGE_TV_CATEGORY=true

# 自定义合并分类
MIGU_CUSTOM_MERGE_CATEGORY=
